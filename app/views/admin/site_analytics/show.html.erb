<div id="site-analytics-root"
     class="mx-auto max-w-7xl space-y-8"
     data-analytics-data-url="<%= admin_site_analytics_site_data_path(@site) %>"
     data-site-token-configured="<%= @site.braiins_pool_auth_token.present? ? "true" : "false" %>"
     data-site-lacks-saved-token="<%= @site.braiins_pool_auth_token.blank? ? "true" : "false" %>"
     data-site-id="<%= @site.id %>"
     data-default-current-machines="<%= @site.default_current_machines %>"
     data-default-projected-machines="<%= @site.default_projected_machines %>">
  <div>
    <p class="text-sm text-gray-500 mb-1">
      <%= link_to "Sites", admin_sites_path, class: "text-blue-600 hover:underline" %>
      <span class="mx-1">/</span>
      <% if @manage_sites %>
        <%= link_to @site.name, admin_site_path(@site), class: "text-blue-600 hover:underline" %>
      <% else %>
        <span><%= @site.name %></span>
      <% end %>
      <span class="mx-1">/</span>
      <span>Pool analytics</span>
    </p>
    <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= @site.name %> — Braiins pool profit</h1>
    <p class="mt-1 text-sm text-gray-600"><%= @site.offering.name %></p>
  </div>

  <div id="status" class="text-sm flex flex-wrap items-baseline gap-x-2 gap-y-1" role="status" aria-live="polite"></div>

  <div id="analytics-tables" class="space-y-6 <%= "hidden" if @site.braiins_pool_auth_token.blank? %>">
    <div id="pool-workers-section">
      <h2 class="mb-2 text-lg font-semibold text-gray-900">Pool workers</h2>
      <p class="mb-3 text-sm text-gray-600">Live worker status from Braiins for this site's pool account.</p>

      <div id="worker-summary-cards" class="mb-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">OK</p>
          <p id="workerCountOk" class="mt-1 text-2xl font-bold text-emerald-700">—</p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Low</p>
          <p id="workerCountLow" class="mt-1 text-2xl font-bold text-amber-700">—</p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Offline</p>
          <p id="workerCountOff" class="mt-1 text-2xl font-bold text-red-700">—</p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Disabled</p>
          <p id="workerCountDis" class="mt-1 text-2xl font-bold text-gray-700">—</p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm col-span-2 sm:col-span-1">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Account hashrate (5m)</p>
          <p id="workerAccountHashrate" class="mt-1 text-lg font-bold text-gray-900">—</p>
        </div>
      </div>

      <div class="relative overflow-y-auto rounded-2xl border border-gray-200 bg-white shadow-sm" style="max-height: 50vh;">
        <div class="analytics-table-loading hidden absolute inset-0 z-20 flex flex-col items-center justify-center gap-3 bg-white/90" aria-hidden="true">
          <svg class="h-8 w-8 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p class="text-sm font-medium text-gray-600">Loading pool data…</p>
        </div>
        <table id="workersTable" class="w-full border-collapse text-right text-sm">
          <thead class="sticky top-0 z-10 bg-gray-50">
            <tr>
              <th class="border border-gray-200 px-3 py-2 text-left min-w-[180px]">Worker</th>
              <th class="border border-gray-200 px-3 py-2 text-left">Status</th>
              <th class="border border-gray-200 px-3 py-2">Hashrate 5m</th>
              <th class="border border-gray-200 px-3 py-2">Hashrate 24h</th>
              <th class="border border-gray-200 px-3 py-2 text-left">Last share</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="mb-2 text-lg font-semibold text-gray-900">Current machines (<span id="currentMachinesHeading"><%= @site.default_current_machines %></span>)</h2>
      <div class="relative overflow-y-auto rounded-2xl border border-gray-200 bg-white shadow-sm" style="max-height: 70vh;">
        <div class="analytics-table-loading hidden absolute inset-0 z-20 flex flex-col items-center justify-center gap-3 bg-white/90" aria-hidden="true">
          <svg class="h-8 w-8 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p class="text-sm font-medium text-gray-600">Loading pool data…</p>
        </div>
        <table id="resultsTableCurrent" class="w-full border-collapse text-right text-sm">
          <thead class="sticky top-0 z-10 bg-gray-50">
            <tr>
              <th class="border border-gray-200 px-3 py-2 text-left min-w-[140px]">Date</th>
              <th class="border border-gray-200 px-3 py-2">Hashrate (TH/s)</th>
              <th class="border border-gray-200 px-3 py-2">Energy Cost (<span id="currentMachinesLabelA"><%= @site.default_current_machines %></span> machines)</th>
              <th class="border border-gray-200 px-3 py-2">BTC Reward</th>
              <th class="border border-gray-200 px-3 py-2">Gross Revenue (USD)</th>
              <th class="border border-gray-200 px-3 py-2">Daily Net Profit (<span id="currentMachinesLabelB"><%= @site.default_current_machines %></span> machines)</th>
              <th class="border border-gray-200 px-3 py-2">Daily Sovrn Partner Return (<span id="currentMachinesLabelC"><%= @site.default_current_machines %></span> machines)</th>
              <th class="border border-gray-200 px-3 py-2">Monthly Sovrn Partner Return (<span id="currentMachinesLabelD"><%= @site.default_current_machines %></span> machines)</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="mb-2 text-lg font-semibold text-gray-900">Projected machines (<span id="projectedMachinesHeading"><%= @site.default_projected_machines %></span>)</h2>
      <div class="relative overflow-y-auto rounded-2xl border border-gray-200 bg-white shadow-sm" style="max-height: 70vh;">
        <div class="analytics-table-loading hidden absolute inset-0 z-20 flex flex-col items-center justify-center gap-3 bg-white/90" aria-hidden="true">
          <svg class="h-8 w-8 animate-spin text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <p class="text-sm font-medium text-gray-600">Loading pool data…</p>
        </div>
        <table id="resultsTableProjected" class="w-full border-collapse text-right text-sm">
          <thead class="sticky top-0 z-10 bg-gray-50">
            <tr>
              <th class="border border-gray-200 px-3 py-2 text-left min-w-[140px]">Date</th>
              <th class="border border-gray-200 px-3 py-2">Hashrate (TH/s)</th>
              <th class="border border-gray-200 px-3 py-2">Energy Cost (<span id="projectedMachinesLabelA"><%= @site.default_projected_machines %></span> machines)</th>
              <th class="border border-gray-200 px-3 py-2">BTC Reward (scaled)</th>
              <th class="border border-gray-200 px-3 py-2">Gross Revenue (USD)</th>
              <th class="border border-gray-200 px-3 py-2">Daily Net Profit (<span id="projectedMachinesLabelB"><%= @site.default_projected_machines %></span> machines)</th>
              <th class="border border-gray-200 px-3 py-2">Daily Sovrn Partner Return (<span id="projectedMachinesLabelC"><%= @site.default_projected_machines %></span> machines)</th>
              <th class="border border-gray-200 px-3 py-2">Monthly Sovrn Partner Return (<span id="projectedMachinesLabelD"><%= @site.default_projected_machines %></span> machines)</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="grid gap-4 md:grid-cols-2">
      <div class="md:col-span-2">
        <% if @manage_sites %>
          <label class="mb-1 block text-sm font-semibold text-gray-700">Braiins API token (Pool-Auth-Token)</label>
          <% if @site.braiins_pool_auth_token.present? %>
            <p id="apiKeySavedHint" class="mb-2 text-sm text-emerald-800">A token is saved for this site. Leave the field blank to use it, or enter a value to override for this session only.</p>
          <% else %>
            <p id="apiKeySavedHint" class="mb-2 text-sm text-amber-900 font-medium">Pool data is hidden until you add a Braiins Pool-Auth-Token. Enter one below and choose “Fetch from API”, or <%= link_to "save a token on the site", edit_admin_site_path(@site), class: "text-blue-700 hover:underline" %> so it loads automatically next time.</p>
          <% end %>
          <input type="password" id="apiKey" value="<%= h(@site.braiins_pool_auth_token.to_s) %>" autocomplete="off" placeholder="Pool-Auth-Token (optional if saved on site)" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-sm text-gray-900">
        <% else %>
          <label class="mb-1 block text-sm font-semibold text-gray-700">Braiins pool data</label>
          <% if @site.braiins_pool_auth_token.present? %>
            <p id="apiKeySavedHint" class="mb-2 text-sm text-emerald-800">Pool data is configured for this site. Use “Fetch from API” to load the latest numbers.</p>
          <% else %>
            <p id="apiKeySavedHint" class="mb-2 text-sm text-amber-900 font-medium">Pool data is not available yet. An administrator needs to configure the Braiins token for this site.</p>
          <% end %>
          <input type="hidden" id="apiKey" value="">
        <% end %>
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">% of S21 Pros</label>
        <input type="number" id="percentPro" value="80" step="0.1" min="0" max="100" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">% of S21</label>
        <input type="number" id="percentStandard" value="20" step="0.1" min="0" max="100" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Weighted Efficiency (J/TH) - auto-calculated</label>
        <input type="number" id="efficiency" value="15.5" step="0.1" readonly class="w-full rounded-xl border border-gray-300 bg-gray-100 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Electricity Cost ($ per kWh)</label>
        <input type="number" id="costPerKwh" value="0.02" step="0.001" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Current Machines</label>
        <input type="number" id="currentMachines" value="<%= @site.default_current_machines %>" step="1" min="1" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Projected Machines</label>
        <input type="number" id="projectedMachines" value="<%= @site.default_projected_machines %>" step="1" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">BTC Price Used (USD)</label>
        <input type="number" id="btcPrice" value="68800" step="1" min="0" class="w-full rounded-xl border border-gray-300 px-3 py-2">
        <p id="btcPriceSource" class="mt-1 text-xs text-gray-500">
          Spot USD is loaded from a public price API (via this app, cached a few minutes). You can override the field anytime.
        </p>
      </div>
    </div>

    <div class="mt-5 flex flex-wrap gap-3">
      <button onclick="fetchFromApi()" class="rounded-xl bg-blue-600 px-5 py-2.5 font-semibold text-white hover:bg-blue-700">
        Fetch from API (Primary)
      </button>
    </div>

    <% unless @manage_sites %>
      <input type="hidden" id="hashrateEndpoint" value="https://pool.braiins.com/accounts/hash_rate_daily/json/btc">
      <input type="hidden" id="rewardsEndpoint" value="https://pool.braiins.com/accounts/rewards/json/btc">
      <textarea id="hrJson" class="hidden" aria-hidden="true"></textarea>
      <textarea id="rewardJson" class="hidden" aria-hidden="true"></textarea>
      <textarea id="rawHashrateResponse" class="hidden" aria-hidden="true"></textarea>
      <textarea id="rawRewardsResponse" class="hidden" aria-hidden="true"></textarea>
    <% end %>
  </div>

  <% if @manage_sites %>
  <details class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <summary class="cursor-pointer text-lg font-semibold text-gray-900">Advanced / Fallback Data (Endpoints + Manual Paste)</summary>

    <div class="mt-5 space-y-5">
      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Hashrate Endpoint</label>
        <input type="text" id="hashrateEndpoint" value="https://pool.braiins.com/accounts/hash_rate_daily/json/btc" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-xs">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Rewards Endpoint</label>
        <input type="text" id="rewardsEndpoint" value="https://pool.braiins.com/accounts/rewards/json/btc" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-xs">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">hash_rate_daily JSON:</label>
        <textarea id="hrJson" rows="12" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-xs">{
  "btc": [
    {"hash_rate_24h": 11883780.516365379, "date": 1774915200},
    {"hash_rate_24h": 13999310.880266042, "date": 1775001600},
    {"hash_rate_24h": 13665345.269348675, "date": 1775088000},
    {"hash_rate_24h": 13615976.128291896, "date": 1775174400},
    {"hash_rate_24h": 13835690.111577524, "date": 1775260800},
    {"hash_rate_24h": 11896272.699169664, "date": 1775347200},
    {"hash_rate_24h": 13895208.406701786, "date": 1775433600},
    {"hash_rate_24h": 47603.152311297519, "date": 1775520000}
  ]
}</textarea>
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">rewards JSON:</label>
        <textarea id="rewardJson" rows="12" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-xs">{
  "btc": {
    "daily_rewards": [
      {"date": 1774915200, "total_reward": "0.00555833"},
      {"date": 1775001600, "total_reward": "0.00652924"},
      {"date": 1775088000, "total_reward": "0.00638066"},
      {"date": 1775174400, "total_reward": "0.00621476"},
      {"date": 1775260800, "total_reward": "0.00621781"},
      {"date": 1775347200, "total_reward": "0.00533394"}
    ]
  }
}</textarea>
      </div>

      <div class="pt-1">
        <button onclick="calculateFromManual()" class="rounded-xl bg-gray-700 px-5 py-2.5 font-semibold text-white hover:bg-gray-800">
          Calculate from Pasted Data
        </button>
      </div>
    </div>
  </details>

  <details class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <summary class="cursor-pointer text-lg font-semibold text-gray-900">API Debug (Raw Responses)</summary>
    <div class="mt-5 space-y-4">
      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Raw Hashrate API Response</label>
        <textarea id="rawHashrateResponse" rows="10" readonly class="w-full rounded-xl border border-gray-300 bg-gray-50 px-3 py-2 font-mono text-xs"></textarea>
      </div>
      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Raw Rewards API Response</label>
        <textarea id="rawRewardsResponse" rows="10" readonly class="w-full rounded-xl border border-gray-300 bg-gray-50 px-3 py-2 font-mono text-xs"></textarea>
      </div>
    </div>
  </details>
  <% end %>

  <p class="text-sm text-gray-600">
    Weighted Efficiency auto-calculated from % mix (80% S21 Pro + 20% S21 = 15.5 J/TH).<br>
    Sovrn Partner Return follows your exact rules: Daily Net Profit − 7% operator − $133.33 generator → Project Profit → DMG 60% → Partner Pool 20% → divided by 4.
  </p>
</div>

<script type="module">
    import {
      computeMachineScales,
      computeWeightedEfficiency as calcWeightedEfficiency,
      computeTableRows,
    } from "site_analytics/calculator";
    import {
      parseWorkerSummary,
      parseWorkerRows,
      workerStateLabel,
      workerStateBadgeClass,
      formatHashRate,
      formatLastShare,
    } from "site_analytics/workers";

    let currentHrData = null;
    let currentRewardData = null;
    let baselineCurrentMachines = null;

    const analyticsRoot = document.getElementById("site-analytics-root");
    const DEFAULT_CURRENT_MACHINES = parseInt(analyticsRoot?.dataset.defaultCurrentMachines, 10) || 80;
    const DEFAULT_PROJECTED_MACHINES = parseInt(analyticsRoot?.dataset.defaultProjectedMachines, 10) || 325;

    function captureBaselineFromInputs() {
      baselineCurrentMachines = parseFloat(document.getElementById("currentMachines").value) || DEFAULT_CURRENT_MACHINES;
    }

    function machineScalesFromInputs() {
      const projectedMachines = document.getElementById("projectedMachines").value;
      const currentMachines = document.getElementById("currentMachines").value;
      return computeMachineScales(projectedMachines, currentMachines, baselineCurrentMachines);
    }

    function showStatus(msg, type = "", meta = null) {
      const el = document.getElementById("status");
      el.className = "text-sm flex flex-wrap items-baseline gap-x-2 gap-y-1";
      el.textContent = "";
      const main = document.createElement("span");
      main.textContent = msg;
      if (type === "error") {
        main.className = "text-red-600";
      } else if (type === "success") {
        main.className = "font-medium text-green-700";
      } else {
        main.className = "text-gray-600";
      }
      el.appendChild(main);

      if (meta && (meta.cachedAt || meta.refreshHours != null)) {
        const suffix = document.createElement("span");
        suffix.className = "text-gray-500";
        const parts = [];
        if (meta.cachedAt) {
          const when = new Date(meta.cachedAt);
          const label = Number.isNaN(when.getTime()) ? String(meta.cachedAt) : when.toLocaleString(undefined, { dateStyle: "medium", timeStyle: "short" });
          parts.push("Last cached " + label + ".");
        }
        const hrs = meta.refreshHours != null ? meta.refreshHours : 6;
        parts.push("Pool data is refetched from Braiins at most every " + hrs + " hours.");
        suffix.textContent = parts.join(" ");
        el.appendChild(suffix);
      }
    }

    function updateDebugPayloads(hashratePayload, rewardsPayload) {
      const hrEl = document.getElementById("rawHashrateResponse");
      const rwEl = document.getElementById("rawRewardsResponse");
      if (hrEl) hrEl.value = hashratePayload ? JSON.stringify(hashratePayload, null, 2) : "";
      if (rwEl) rwEl.value = rewardsPayload ? JSON.stringify(rewardsPayload, null, 2) : "";
    }

    function updateWeightedEfficiency() {
      const percentPro = document.getElementById("percentPro").value;
      const percentStandard = document.getElementById("percentStandard").value;
      document.getElementById("efficiency").value = calcWeightedEfficiency(percentPro, percentStandard).toFixed(2);
    }

    function updateProjectedMachineLabels() {
      const projectedMachines = parseFloat(document.getElementById("projectedMachines").value) || DEFAULT_PROJECTED_MACHINES;
      const text = String(projectedMachines);
      ["projectedMachinesHeading", "projectedMachinesLabelA", "projectedMachinesLabelB", "projectedMachinesLabelC", "projectedMachinesLabelD"].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = text;
      });
    }

    function updateCurrentMachineLabels() {
      const currentMachines = parseFloat(document.getElementById("currentMachines").value) || DEFAULT_CURRENT_MACHINES;
      const text = String(currentMachines);
      ["currentMachinesHeading", "currentMachinesLabelA", "currentMachinesLabelB", "currentMachinesLabelC", "currentMachinesLabelD"].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = text;
      });
    }

    function calculateFromManual() {
      const typedToken = document.getElementById("apiKey").value.trim();
      if (siteLacksSavedToken() && !typedToken) {
        clearAnalyticsTables();
        showStatus("Add a Braiins Pool-Auth-Token above (or save one when editing this site) to load pool data. No data is shown without a token.", "error");
        return;
      }

      const eff = parseFloat(document.getElementById("efficiency").value) || 15.5;
      const costKwh = parseFloat(document.getElementById("costPerKwh").value) || 0.02;
      const btcPrice = parseFloat(document.getElementById("btcPrice").value) || 68800;
      updateProjectedMachineLabels();
      updateCurrentMachineLabels();

      try {
        const hrText = document.getElementById("hrJson").value.trim();
        const rewardText = document.getElementById("rewardJson").value.trim();

        currentHrData = JSON.parse(hrText);
        currentRewardData = JSON.parse(rewardText);

        if (!currentHrData?.btc || !currentRewardData?.btc?.daily_rewards) {
          showStatus("JSON structure incorrect.", "error");
          return;
        }

        captureBaselineFromInputs();
        const { currentScale, projectedScale } = machineScalesFromInputs();
        renderTable(currentHrData.btc, currentRewardData.btc.daily_rewards, eff, costKwh, currentScale, projectedScale, btcPrice);
        showStatus("✅ Table calculated successfully.", "success");

      } catch (e) {
        showStatus("❌ JSON parse error.", "error");
      }
    }

    function recalculateFromCurrentData() {
      if (!currentHrData?.btc || !currentRewardData?.btc?.daily_rewards) return;

      const eff = parseFloat(document.getElementById("efficiency").value) || 15.5;
      const costKwh = parseFloat(document.getElementById("costPerKwh").value) || 0.02;
      const btcPrice = parseFloat(document.getElementById("btcPrice").value) || 68800;
      updateProjectedMachineLabels();
      updateCurrentMachineLabels();

      const { currentScale, projectedScale } = machineScalesFromInputs();
      renderTable(currentHrData.btc, currentRewardData.btc.daily_rewards, eff, costKwh, currentScale, projectedScale, btcPrice);
    }

    function normalizeHashratePayload(payload) {
      if (payload?.btc && Array.isArray(payload.btc)) return payload.btc;
      if (Array.isArray(payload?.hash_rate_daily)) return payload.hash_rate_daily;
      if (Array.isArray(payload?.data?.btc)) return payload.data.btc;
      return null;
    }

    function normalizeRewardsPayload(payload) {
      if (payload?.btc?.daily_rewards && Array.isArray(payload.btc.daily_rewards)) return payload.btc.daily_rewards;
      if (Array.isArray(payload?.daily_rewards)) return payload.daily_rewards;
      if (Array.isArray(payload?.data?.daily_rewards)) return payload.data.daily_rewards;
      return null;
    }

    async function fetchBtcPriceUsd() {
      const hint = document.getElementById("btcPriceSource");
      const input = document.getElementById("btcPrice");
      try {
        const res = await fetch("/admin/site_analytics/btc_price", {
          headers: { Accept: "application/json" }
        });
        if (!res.ok) throw new Error("HTTP " + res.status);
        const data = await res.json();
        if (data.error || typeof data.usd !== "number") throw new Error(data.error || "bad response");
        const rounded = Math.round(data.usd * 100) / 100;
        input.value = String(rounded);
        const src = data.source || "API";
        const ttl = data.cache_ttl_minutes != null ? data.cache_ttl_minutes : 5;
        let line = "Spot USD from " + src + ", via server (cached up to " + ttl + " min). Override anytime.";
        if (data.fetched_at) {
          const when = new Date(data.fetched_at);
          if (!Number.isNaN(when.getTime())) {
            line += " Price snapshot: " + when.toLocaleString(undefined, { dateStyle: "medium", timeStyle: "short" }) + ".";
          }
        }
        hint.textContent = line;
      } catch (e) {
        hint.textContent = "Could not load live BTC/USD; using the value in the field above. (" + String(e.message) + ")";
      }
    }

    function analyticsDataPostUrl() {
      const fromData = document.getElementById("site-analytics-root")?.dataset?.analyticsDataUrl;
      if (!fromData) throw new Error("Missing pool analytics data URL.");
      return fromData;
    }

    function siteTokenConfigured() {
      const root = document.getElementById("site-analytics-root");
      return root?.dataset?.siteTokenConfigured === "true";
    }

    function siteLacksSavedToken() {
      const root = document.getElementById("site-analytics-root");
      return root?.dataset?.siteLacksSavedToken === "true";
    }

    function revealAnalyticsTables() {
      document.getElementById("analytics-tables")?.classList.remove("hidden");
    }

    function setTablesLoading(isLoading) {
      document.querySelectorAll(".analytics-table-loading").forEach(el => {
        el.classList.toggle("hidden", !isLoading);
        el.setAttribute("aria-hidden", isLoading ? "false" : "true");
      });
      const tablesRoot = document.getElementById("analytics-tables");
      if (tablesRoot) tablesRoot.setAttribute("aria-busy", isLoading ? "true" : "false");
    }

    function clearWorkers() {
      ["workerCountOk", "workerCountLow", "workerCountOff", "workerCountDis", "workerAccountHashrate"].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = "—";
      });
      const tbody = document.getElementById("workersTable")?.querySelector("tbody");
      if (tbody) tbody.innerHTML = "";
    }

    function clearAnalyticsTables() {
      setTablesLoading(false);
      currentHrData = null;
      currentRewardData = null;
      baselineCurrentMachines = null;
      clearWorkers();
      ["resultsTableCurrent", "resultsTableProjected"].forEach(tableId => {
        const table = document.getElementById(tableId);
        const tbody = table?.querySelector("tbody");
        if (tbody) tbody.innerHTML = "";
      });
    }

    async function fetchFromApi() {
      await fetchBtcPriceUsd();
      const token = document.getElementById("apiKey").value.trim();
      const hashrateEndpoint = document.getElementById("hashrateEndpoint").value.trim();
      const rewardsEndpoint = document.getElementById("rewardsEndpoint").value.trim();
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;

      if (!token && !siteTokenConfigured()) {
        clearAnalyticsTables();
        showStatus("Add a Braiins Pool-Auth-Token above (or save one when editing this site) to load pool data. No data is shown without a token.", "error");
        return;
      }

      try {
        revealAnalyticsTables();
        setTablesLoading(true);
        showStatus("Loading from Braiins API...");
        const proxyRes = await fetch(analyticsDataPostUrl(), {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": csrfToken
          },
          body: JSON.stringify({
            api_key: token,
            hashrate_endpoint: hashrateEndpoint,
            rewards_endpoint: rewardsEndpoint
          })
        });

        const proxyPayload = await proxyRes.json();
        if (!proxyRes.ok) {
          const msg = proxyPayload.error || `HTTP ${proxyRes.status}`;
          throw new Error(msg);
        }
        const hrPayload = proxyPayload.hashrate;
        const rwPayload = proxyPayload.rewards;
        updateDebugPayloads(hrPayload, rwPayload);
        const hrArray = normalizeHashratePayload(hrPayload);
        const rewardArray = normalizeRewardsPayload(rwPayload);

        if (!hrArray || !rewardArray) {
          throw new Error("Unexpected API response shape.");
        }

        currentHrData = { btc: hrArray };
        currentRewardData = { btc: { daily_rewards: rewardArray } };

        captureBaselineFromInputs();
        const eff = parseFloat(document.getElementById("efficiency").value) || 15.5;
        const costKwh = parseFloat(document.getElementById("costPerKwh").value) || 0.02;
        updateProjectedMachineLabels();
        updateCurrentMachineLabels();

        const btcPrice = parseFloat(document.getElementById("btcPrice").value) || 68800;
        const { currentScale, projectedScale } = machineScalesFromInputs();
        renderTable(hrArray, rewardArray, eff, costKwh, currentScale, projectedScale, btcPrice);
        renderWorkers(proxyPayload.profile, proxyPayload.workers);
        const cachedAtRaw = proxyPayload.cached_at != null ? proxyPayload.cached_at : proxyPayload.cachedAt;
        const refreshHrs = proxyPayload.refresh_interval_hours != null ? proxyPayload.refresh_interval_hours : proxyPayload.refreshIntervalHours;
        showStatus("✅ Loaded from Braiins API.", "success", {
          cachedAt: cachedAtRaw,
          refreshHours: refreshHrs != null ? refreshHrs : 6
        });
      } catch (e) {
        setTablesLoading(false);
        showStatus("⚠️ " + String(e.message) + " — using manual pasted data if available.", "error");
        updateDebugPayloads(
          { error: "API request failed", message: String(e) },
          { error: "API request failed", message: String(e) }
        );
        const typedToken = document.getElementById("apiKey").value.trim();
        if (!siteLacksSavedToken() || typedToken) {
          calculateFromManual();
        } else {
          clearAnalyticsTables();
        }
      }
    }

    function formatTableDateMmDdYy(unixSeconds) {
      const d = new Date(unixSeconds * 1000);
      const mm = String(d.getUTCMonth() + 1).padStart(2, "0");
      const dd = String(d.getUTCDate()).padStart(2, "0");
      const yy = String(d.getUTCFullYear()).slice(-2);
      return `${mm}/${dd}/${yy}`;
    }

    function renderWorkers(profilePayload, workersPayload) {
      revealAnalyticsTables();

      const summary = parseWorkerSummary(profilePayload);
      document.getElementById("workerCountOk").textContent = String(summary.ok);
      document.getElementById("workerCountLow").textContent = String(summary.low);
      document.getElementById("workerCountOff").textContent = String(summary.off);
      document.getElementById("workerCountDis").textContent = String(summary.dis);
      document.getElementById("workerAccountHashrate").textContent = formatHashRate(summary.hashRate5m, summary.unit);

      const tbody = document.getElementById("workersTable").querySelector("tbody");
      tbody.innerHTML = "";

      const rows = parseWorkerRows(workersPayload);
      if (rows.length === 0) {
        const emptyRow = document.createElement("tr");
        emptyRow.innerHTML = `<td colspan="5" class="px-3 py-4 text-center text-sm text-gray-500">No workers reported for this pool account.</td>`;
        tbody.appendChild(emptyRow);
        return;
      }

      rows.forEach(row => {
        const tr = document.createElement("tr");
        const badgeClass = workerStateBadgeClass(row.state);
        const label = workerStateLabel(row.state);
        tr.innerHTML = `
          <td class="text-left px-3 py-2 font-mono text-xs">${row.name}</td>
          <td class="text-left px-3 py-2"><span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold ${badgeClass}">${label}</span></td>
          <td class="px-3 py-2">${formatHashRate(row.hashRate5m, row.unit)}</td>
          <td class="px-3 py-2">${formatHashRate(row.hashRate24h, row.unit)}</td>
          <td class="text-left px-3 py-2">${formatLastShare(row.lastShareAt)}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    function renderTable(hrArray, rewardArray, efficiency, costKwh, currentScale, projectedScale, btcPrice) {
      revealAnalyticsTables();
      setTablesLoading(false);
      const tbodyCurrent = document.getElementById("resultsTableCurrent").querySelector("tbody");
      const tbodyProjected = document.getElementById("resultsTableProjected").querySelector("tbody");
      tbodyCurrent.innerHTML = "";
      tbodyProjected.innerHTML = "";

      const rows = computeTableRows(hrArray, rewardArray, efficiency, costKwh, currentScale, projectedScale, btcPrice);

      rows.forEach(row => {
        const dateStr = formatTableDateMmDdYy(row.date);

        const rowCurrent = document.createElement("tr");
        rowCurrent.innerHTML = `
          <td class="text-left min-w-[140px] px-3 py-2">${dateStr}</td>
          <td class="px-3 py-2">${row.ths.toFixed(2)}</td>
          <td class="px-3 py-2">$${row.elecCostCurrent.toFixed(2)}</td>
          <td class="px-3 py-2">${row.btcReward.toFixed(8)}</td>
          <td class="px-3 py-2">$${row.gross.toFixed(2)}</td>
          <td class="px-3 py-2 ${row.netCurrent >= 0 ? "text-green-700 font-semibold" : "text-red-600 font-semibold"}">$${row.netCurrent.toFixed(2)}</td>
          <td class="px-3 py-2 ${row.sovrnCurrent >= 0 ? "text-green-700 font-semibold" : "text-red-600 font-semibold"}">$${row.sovrnCurrent.toFixed(2)}</td>
          <td class="px-3 py-2 ${row.sovrn30Current >= 0 ? "text-green-700 font-semibold" : "text-red-600 font-semibold"}">$${row.sovrn30Current.toFixed(2)}</td>
        `;
        tbodyCurrent.appendChild(rowCurrent);

        const rowProjected = document.createElement("tr");
        rowProjected.innerHTML = `
          <td class="text-left min-w-[140px] px-3 py-2">${dateStr}</td>
          <td class="px-3 py-2">${row.thsProjected.toFixed(2)}</td>
          <td class="px-3 py-2">$${row.elecCostProjected.toFixed(2)}</td>
          <td class="px-3 py-2">${row.btcRewardScaled.toFixed(8)}</td>
          <td class="px-3 py-2">$${row.grossProjected.toFixed(2)}</td>
          <td class="px-3 py-2 ${row.netProjected >= 0 ? "text-green-700 font-semibold" : "text-red-600 font-semibold"}">$${row.netProjected.toFixed(2)}</td>
          <td class="px-3 py-2 ${row.sovrnProjected >= 0 ? "text-green-700 font-semibold" : "text-red-600 font-semibold"}">$${row.sovrnProjected.toFixed(2)}</td>
          <td class="px-3 py-2 ${row.sovrn30Projected >= 0 ? "text-green-700 font-semibold" : "text-red-600 font-semibold"}">$${row.sovrn30Projected.toFixed(2)}</td>
        `;
        tbodyProjected.appendChild(rowProjected);
      });
    }

    // Auto-update weighted efficiency
    document.getElementById("percentPro").addEventListener("input", updateWeightedEfficiency);
    document.getElementById("percentStandard").addEventListener("input", updateWeightedEfficiency);

    // Auto-recalculate table
    ["efficiency", "costPerKwh", "currentMachines", "projectedMachines", "btcPrice", "percentPro", "percentStandard"].forEach(id => {
      document.getElementById(id).addEventListener("input", () => {
        updateProjectedMachineLabels();
        updateCurrentMachineLabels();
        recalculateFromCurrentData();
      });
    });

    async function initSiteAnalyticsPage() {
      if (!document.getElementById("site-analytics-root")) return;
      updateWeightedEfficiency();
      updateProjectedMachineLabels();
      updateCurrentMachineLabels();

      if (siteLacksSavedToken()) {
        clearAnalyticsTables();
        await fetchBtcPriceUsd();
        showStatus("Add a Braiins Pool-Auth-Token above (or save one when editing this site) to load pool data. No data is shown without a token.", "error");
        return;
      }

      await fetchFromApi();
    }

    if (!window.__siteAnalyticsTurboInit) {
      window.__siteAnalyticsTurboInit = true;
      document.addEventListener("turbo:load", initSiteAnalyticsPage);
    }

    window.fetchFromApi = fetchFromApi;
    window.calculateFromManual = calculateFromManual;
</script>
