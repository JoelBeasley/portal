<div class="mx-auto max-w-7xl space-y-8">
  <div>
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Braiins Pool Profit Dashboard</h1>
  </div>

  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="grid gap-4 md:grid-cols-2">
      <div class="md:col-span-2">
        <label class="mb-1 block text-sm font-semibold text-gray-700">Braiins API Token (Pool-Auth-Token):</label>
        <input type="text" id="apiKey" value="B6ct1yLY2UfPYfuk" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-sm">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">% of S21 Pros</label>
        <input type="number" id="percentPro" value="80" step="0.1" min="0" max="100" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">% of S21</label>
        <input type="number" id="percentStandard" value="20" step="0.1" min="0" max="100" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Weighted Efficiency (J/TH) - auto-calculated</label>
        <input type="number" id="efficiency" value="15.5" step="0.1" readonly class="w-full rounded-xl border border-gray-300 bg-gray-100 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Electricity Cost ($ per kWh)</label>
        <input type="number" id="costPerKwh" value="0.02" step="0.001" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>

      <div>
        <label class="mb-1 block text-sm font-semibold text-gray-700">Projected Machines</label>
        <input type="number" id="projectedMachines" value="325" step="1" class="w-full rounded-xl border border-gray-300 px-3 py-2">
      </div>
    </div>

    <button onclick="calculateFromManual()" class="mt-5 rounded-xl bg-blue-600 px-5 py-2.5 font-semibold text-white hover:bg-blue-700">
      Calculate from Pasted Data
    </button>
  </div>

  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h3 class="mb-4 text-lg font-semibold text-gray-900">Manual Paste (pre-filled with your data)</h3>

    <label class="mb-1 block text-sm font-semibold text-gray-700">hash_rate_daily JSON:</label>
    <textarea id="hrJson" rows="12" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-xs">{
  "btc": [
    {"hash_rate_24h": 11883780.516365379, "date": 1774915200},
    {"hash_rate_24h": 13999310.880266042, "date": 1775001600},
    {"hash_rate_24h": 13665345.269348675, "date": 1775088000},
    {"hash_rate_24h": 13615976.128291896, "date": 1775174400},
    {"hash_rate_24h": 13835690.111577524, "date": 1775260800},
    {"hash_rate_24h": 11896272.699169664, "date": 1775347200},
    {"hash_rate_24h": 13895208.406701786, "date": 1775433600},
    {"hash_rate_24h": 47603.152311297519, "date": 1775520000}
  ]
}</textarea>

    <label class="mb-1 mt-4 block text-sm font-semibold text-gray-700">rewards JSON:</label>
    <textarea id="rewardJson" rows="12" class="w-full rounded-xl border border-gray-300 px-3 py-2 font-mono text-xs">{
  "btc": {
    "daily_rewards": [
      {"date": 1774915200, "total_reward": "0.00555833"},
      {"date": 1775001600, "total_reward": "0.00652924"},
      {"date": 1775088000, "total_reward": "0.00638066"},
      {"date": 1775174400, "total_reward": "0.00621476"},
      {"date": 1775260800, "total_reward": "0.00621781"},
      {"date": 1775347200, "total_reward": "0.00533394"}
    ]
  }
}</textarea>
  </div>

  <div id="status" class="text-sm text-gray-600"></div>

  <div class="overflow-y-auto rounded-2xl border border-gray-200 bg-white shadow-sm" style="max-height: 70vh;">
    <table id="resultsTable" class="w-full border-collapse text-right text-sm">
      <thead class="sticky top-0 z-10 bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2">Date</th>
          <th class="border border-gray-200 px-3 py-2">Hashrate (TH/s)</th>
          <th class="border border-gray-200 px-3 py-2">Energy Cost (80 machines)</th>
          <th class="border border-gray-200 px-3 py-2">Energy Cost (325 machines)</th>
          <th class="border border-gray-200 px-3 py-2">BTC Reward</th>
          <th class="border border-gray-200 px-3 py-2">Gross Revenue (USD)</th>
          <th class="border border-gray-200 px-3 py-2">Net Profit (80 machines)</th>
          <th class="border border-gray-200 px-3 py-2">Net Profit (325 machines)</th>
          <th class="border border-gray-200 px-3 py-2">Sovrn Partner Return (80 machines)</th>
          <th class="border border-gray-200 px-3 py-2">Sovrn Partner Return (325 machines)</th>
          <th class="border border-gray-200 px-3 py-2">Sovrn Partner Return 30 Days (80 machines)</th>
          <th class="border border-gray-200 px-3 py-2">Sovrn Partner Return 30 Days (325 machines)</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>

  <p class="text-sm text-gray-600">
    Weighted Efficiency auto-calculated from % mix (80% S21 Pro + 20% S21 = 15.5 J/TH).<br>
    Sovrn Partner Return follows your exact rules: Net Profit − 7% operator − $133.33 generator → Project Profit → DMG 60% → Partner Pool 20% → divided by 4.
  </p>
</div>

<script>
    let currentHrData = null;
    let currentRewardData = null;

    function showStatus(msg, type = "") {
      const el = document.getElementById("status");
      el.textContent = msg;
      el.style.color = type === "error" ? "red" : (type === "success" ? "green" : "#666");
    }

    function updateWeightedEfficiency() {
      const percentPro = parseFloat(document.getElementById("percentPro").value) || 0;
      const percentStandard = parseFloat(document.getElementById("percentStandard").value) || 0;
      const effPro = 15.0;
      const effStandard = 17.5;
      const weighted = (percentPro / 100 * effPro) + (percentStandard / 100 * effStandard);
      document.getElementById("efficiency").value = weighted.toFixed(2);
    }

    function calculateFromManual() {
      const eff = parseFloat(document.getElementById("efficiency").value) || 15.5;
      const costKwh = parseFloat(document.getElementById("costPerKwh").value) || 0.02;
      const projectedMachines = parseFloat(document.getElementById("projectedMachines").value) || 325;
      const currentMachines = 80;
      const scaleFactor = projectedMachines / currentMachines;

      try {
        const hrText = document.getElementById("hrJson").value.trim();
        const rewardText = document.getElementById("rewardJson").value.trim();

        currentHrData = JSON.parse(hrText);
        currentRewardData = JSON.parse(rewardText);

        if (!currentHrData?.btc || !currentRewardData?.btc?.daily_rewards) {
          showStatus("JSON structure incorrect.", "error");
          return;
        }

        renderTable(currentHrData.btc, currentRewardData.btc.daily_rewards, eff, costKwh, scaleFactor);
        showStatus("✅ Table calculated successfully.", "success");

      } catch (e) {
        showStatus("❌ JSON parse error.", "error");
      }
    }

    function renderTable(hrArray, rewardArray, efficiency, costKwh, scaleFactor) {
      const tbody = document.getElementById("resultsTable").querySelector("tbody");
      tbody.innerHTML = "";

      const rewardMap = {};
      rewardArray.forEach(r => {
        if (r.date) rewardMap[r.date] = parseFloat(r.total_reward) || 0;
      });

      hrArray.forEach(day => {
        const dateUnix = day.date;
        const hashratePh = parseFloat(day.hash_rate_24h) || 0;
        const ths = hashratePh / 1000;

        // Current (80 machines)
        const powerKwCurrent = (ths * efficiency) / 1000;
        const dailyKwhCurrent = powerKwCurrent * 24;
        const elecCostCurrent = dailyKwhCurrent * costKwh;
        const btcReward = rewardMap[dateUnix] || 0;
        const gross = btcReward * 68800;
        const netCurrent = gross - elecCostCurrent;

        // Projected (325 machines)
        const thsProjected = ths * scaleFactor;
        const powerKwProjected = (thsProjected * efficiency) / 1000;
        const dailyKwhProjected = powerKwProjected * 24;
        const elecCostProjected = dailyKwhProjected * costKwh;
        const grossProjected = gross * scaleFactor;
        const netProjected = grossProjected - elecCostProjected;

        // Sovrn calculation for current
        const operatorCostCurrent = netCurrent * 0.07;
        const generatorCost = 4000 / 30;
        const projectProfitCurrent = netCurrent - operatorCostCurrent - generatorCost;
        const dmgProfitCurrent = projectProfitCurrent * 0.60;
        const partnerPoolCurrent = dmgProfitCurrent * 0.20;
        const sovrnCurrent = partnerPoolCurrent / 4;
        const sovrn30Current = sovrnCurrent * 30;

        // Sovrn calculation for projected
        const operatorCostProjected = netProjected * 0.07;
        const projectProfitProjected = netProjected - operatorCostProjected - generatorCost;
        const dmgProfitProjected = projectProfitProjected * 0.60;
        const partnerPoolProjected = dmgProfitProjected * 0.20;
        const sovrnProjected = partnerPoolProjected / 4;
        const sovrn30Projected = sovrnProjected * 30;

        const row = document.createElement("tr");
        row.innerHTML = `
          <td>${new Date(dateUnix * 1000).toISOString().split('T')[0]}</td>
          <td>${ths.toFixed(2)}</td>
          <td>$${elecCostCurrent.toFixed(4)}</td>
          <td>$${elecCostProjected.toFixed(4)}</td>
          <td>${btcReward.toFixed(8)}</td>
          <td>$${gross.toFixed(2)}</td>
          <td class="${netCurrent >= 0 ? 'text-green-700 font-semibold' : 'text-red-600 font-semibold'}">$${netCurrent.toFixed(2)}</td>
          <td class="${netProjected >= 0 ? 'text-green-700 font-semibold' : 'text-red-600 font-semibold'}">$${netProjected.toFixed(2)}</td>
          <td class="${sovrnCurrent >= 0 ? 'text-green-700 font-semibold' : 'text-red-600 font-semibold'}">$${sovrnCurrent.toFixed(2)}</td>
          <td class="${sovrnProjected >= 0 ? 'text-green-700 font-semibold' : 'text-red-600 font-semibold'}">$${sovrnProjected.toFixed(2)}</td>
          <td class="${sovrn30Current >= 0 ? 'text-green-700 font-semibold' : 'text-red-600 font-semibold'}">$${sovrn30Current.toFixed(2)}</td>
          <td class="${sovrn30Projected >= 0 ? 'text-green-700 font-semibold' : 'text-red-600 font-semibold'}">$${sovrn30Projected.toFixed(2)}</td>
        `;
        tbody.appendChild(row);
      });
    }

    // Auto-update weighted efficiency
    document.getElementById("percentPro").addEventListener("input", updateWeightedEfficiency);
    document.getElementById("percentStandard").addEventListener("input", updateWeightedEfficiency);

    // Auto-recalculate table
    ["efficiency", "costPerKwh", "projectedMachines", "percentPro", "percentStandard"].forEach(id => {
      document.getElementById(id).addEventListener("input", () => {
        if (currentHrData && currentRewardData) calculateFromManual();
      });
    });

    // Initial load
    window.onload = () => {
      updateWeightedEfficiency();
      calculateFromManual();
    };
</script>
