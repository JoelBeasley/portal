<p style="margin: 0 0 12px; font-size: 20px; font-weight: 700; color: #111827;">Email updated</p>

<p style="margin: 0 0 14px;">Hi <strong><%= @email %></strong>,</p>

<% if @resource.try(:unconfirmed_email?) %>
  <p style="margin: 0;">
    We’re notifying you that your email is being changed to <strong><%= @resource.unconfirmed_email %></strong>.
  </p>
<% else %>
  <p style="margin: 0;">
    We’re notifying you that your account email has been changed to <strong><%= @resource.email %></strong>.
  </p>
<% end %>
